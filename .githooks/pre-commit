#!/bin/bash

echo "🧹 Automated import cleanup and validation tracking..."

# 1. Get the list of currently staged files
STAGED_FILES=$(git diff --cached --name-only)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

# 2. Build a comma-separated list of staged Java files for Spotless
SPOTLESS_TARGETS=""
for FILE in $STAGED_FILES; do
    if [[ "$FILE" == *.java ]] && [ -f "$FILE" ]; then
        if [ -z "$SPOTLESS_TARGETS" ]; then
            SPOTLESS_TARGETS="$FILE"
        else
            SPOTLESS_TARGETS="$SPOTLESS_TARGETS,$FILE"
        fi
    fi
done

# 3. Only run Spotless if there are staged Java files to clean
if [ ! -z "$SPOTLESS_TARGETS" ]; then
    echo "✨ Running Spotless on staged files only..."
    mvn spotless:apply -DspotlessFiles="$SPOTLESS_TARGETS"
fi

# 4. Block commit if staged test files contain TestDebugger calls
HAS_DEBUG=false

for FILE in $STAGED_FILES; do
    if [[ "$FILE" == src/test/* ]] && [[ "$FILE" != *TestDebugger.java ]] && [ -f "$FILE" ]; then
        if grep -E -q "TestDebugger\.(print|render)[a-zA-Z]*\(" "$FILE"; then
            echo "❌ TestDebugger call detected in: $FILE"
            HAS_DEBUG=true
        fi
    fi
done

if [ "$HAS_DEBUG" = true ]; then
    echo ""
    echo "Commit aborted."
    echo "Remove all TestDebugger calls before committing."
    exit 1
fi

# 5. Re-stage files that were ALREADY staged and modified by Spotless
for FILE in $STAGED_FILES; do
    if [ -f "$FILE" ]; then
        git add "$FILE"
    fi
done

# 6. WARNING: Check for active TestDebugger calls in modified but UNSTAGED files
UNSTAGED_FILES=$(git diff --name-only)
HAS_UNSTAGED_DEBUG=false

for FILE in $UNSTAGED_FILES; do
    if [[ "$FILE" == src/test/* ]] && [[ "$FILE" != *TestDebugger.java ]] && [ -f "$FILE" ]; then
        # Here we look for the actual Java call since Spotless didn't touch these files
        if grep -E -q "TestDebugger\.(print|render)" "$FILE"; then
            if [ "$HAS_UNSTAGED_DEBUG" = false ]; then
                echo "⚠️  Keep in mind: You have active debug sessions in unstaged files:"
                HAS_UNSTAGED_DEBUG=true
            fi
            echo "   -> $FILE"
        fi
    fi
done

exit 0